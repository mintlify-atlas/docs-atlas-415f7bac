  "keyFeatures": [
    "S3-compatible object storage",
    "Geo-distributed replication",
    "Self-contained deployment with no external dependencies",
    "Flexible cluster topology with automatic rebalancing",
    "Multiple replication modes with configurable consistency",
    "Built-in data deduplication and compression",
    "Static website hosting",
    "Admin API for cluster management",
    "K2V API for small value storage",
    "No RAFT consensus for better performance",
    "Multi-datacenter support",
    "Prometheus metrics"
  ],
  "publicApiSurface": [
    "garage server - Start Garage server",
    "garage status - Get network status",
    "garage node id - Print node ID",
    "garage node connect - Connect to isolated node",
    "garage layout assign - Assign role to node",
    "garage layout remove - Remove role from node",
    "garage layout show - Show cluster layout",
    "garage layout apply - Apply layout changes",
    "garage bucket create - Create bucket",
    "garage bucket list - List buckets",
    "garage bucket info - Show bucket info",
    "garage bucket allow - Grant bucket permissions",
    "garage bucket deny - Revoke bucket permissions",
    "garage key create - Create API key",
    "garage key list - List API keys",
    "garage key info - Show key info",
    "garage repair - Start data repair",
    "garage stats - Gather node statistics",
    "garage worker - Manage background workers",
    "S3 API - Full S3-compatible REST API",
    "Admin API - Cluster administration REST API",
    "K2V API - Key-value storage API"
  ]
